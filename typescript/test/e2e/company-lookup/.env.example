# Copy this file to .env and adjust as needed. See:
# https://sovdev-logger.sovereignsky.no/contributor/testing/uis
#
# These defaults point at a local UIS (Urbalurba Infrastructure Stack)
# observability stack, reached from inside the sovdev-logger devcontainer via
# host.docker.internal + an explicit Host header (Traefik routes by hostname,
# not by port, so the header is what selects the otel-collector IngressRoute).

OTEL_SERVICE_NAME=sovdev-test-company-lookup-typescript
OTEL_EXPORTER_OTLP_LOGS_ENDPOINT=http://host.docker.internal/v1/logs
OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=http://host.docker.internal/v1/metrics
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://host.docker.internal/v1/traces

# IMPORTANT: this value must be single-quoted in this file. run-test.sh loads
# it with `source .env`, and bash strips unquoted/double-quoted `"` characters
# during word-splitting -- an unquoted {"Host":"otel.localhost"} becomes the
# invalid JSON {Host:otel.localhost} once bash is done with it, which fails
# silently inside the SDK (metrics/traces never initialize, but the app
# keeps running) rather than erroring loudly. Confirmed by hitting this
# exact bug: it manifested as every company lookup failing with "TracerProvider
# not initialized", not as a visible JSON error.
OTEL_EXPORTER_OTLP_HEADERS='{"Host":"otel.localhost"}'

OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
LOG_TO_FILE=true
LOG_TO_CONSOLE=true
