# Raw input for onboard-system.sh -- the only file a contributor needs to
# hand-fill after creating a new system's two Access Policies in the
# Grafana Cloud portal (see using/onboarding/index.md steps 2-3).
#
# Copy this to a real file (e.g. terchris/<system>-raw.env -- gitignored,
# real secrets never committed), fill in the 3 values below, then run:
#
#   ./onboard-system.sh <your-copy> <output-handover-file>
#
# Everything else (OTLP/Loki/Prometheus/Tempo endpoints and Instance IDs) is
# a stack-wide constant the script fills in itself -- confirmed identical
# for every system on this stack (urbalurba). Only set the OVERRIDE_* lines
# if this system is ever on a genuinely different stack.

SERVICE_NAME=
INGEST_TOKEN=
VERIFY_TOKEN=

# --- Overrides (leave blank to use this stack's known defaults) ---
OVERRIDE_OTLP_ENDPOINT=
OVERRIDE_OTLP_INSTANCE_ID=
OVERRIDE_LOKI_URL=
OVERRIDE_LOKI_INSTANCE_ID=
OVERRIDE_PROMETHEUS_URL=
OVERRIDE_PROMETHEUS_INSTANCE_ID=
OVERRIDE_TEMPO_URL=
OVERRIDE_TEMPO_INSTANCE_ID=
