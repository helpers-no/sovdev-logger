# Copy this file to .env and fill in real values from your Grafana Cloud
# portal (Security -> Access Policies for tokens; each stack's Loki/Tempo/
# Prometheus connection page for the base URLs and Instance IDs).
#
# Two separate tokens, least-privilege:
#   - GRAFANA_CLOUD_INGEST_TOKEN: metrics:write + logs:write + traces:write,
#     used by the E2E test's OTLP exporter config to push telemetry.
#   - GRAFANA_CLOUD_VERIFY_TOKEN: metrics:read + logs:read + traces:read,
#     used by these query-*.ts scripts to read it back.
# Both should be scoped to a single stack (Realm), not the whole org.

GRAFANA_CLOUD_INGEST_TOKEN=
GRAFANA_CLOUD_VERIFY_TOKEN=

# OTLP push gateway (one endpoint for all three signals) + the OTLP-specific
# Instance ID used as the Basic Auth username when pushing.
GRAFANA_CLOUD_OTLP_ENDPOINT=https://otlp-gateway-prod-eu-west-0.grafana.net/otlp
GRAFANA_CLOUD_OTLP_INSTANCE_ID=

# Per-signal query hosts + Instance IDs. Confirmed non-uniform naming across
# signals -- don't assume a shared "*-prod-*" pattern (see
# INVESTIGATE-grafana-cloud-validator.md).
GRAFANA_CLOUD_LOKI_URL=https://logs-prod-eu-west-0.grafana.net
GRAFANA_CLOUD_LOKI_INSTANCE_ID=

GRAFANA_CLOUD_TEMPO_URL=https://tempo-eu-west-0.grafana.net
GRAFANA_CLOUD_TEMPO_INSTANCE_ID=

GRAFANA_CLOUD_PROMETHEUS_URL=https://prometheus-prod-01-eu-west-0.grafana.net
GRAFANA_CLOUD_PROMETHEUS_INSTANCE_ID=
